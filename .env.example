# Shopify Admin API
SHOPIFY_STORE_URL=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxx

# 対象商品のフィルタ条件（メタフィールド custom.wisdomguild = true の商品を対象）
FILTER_METAFIELD_NAMESPACE=custom
FILTER_METAFIELD_KEY=wisdomguild

# 商品コードのソース
#   variant_sku       : variant.sku を商品コードとして出力（既定）
#   product_metafield : 商品メタフィールド値を商品コードとして出力（同一商品の全行で同値）
ITEMCODE_SOURCE=variant_sku
ITEMCODE_METAFIELD_NAMESPACE=custom
ITEMCODE_METAFIELD_KEY=itemcode

# 販売可能性の厳密フィルタ（既定: 無効）
#   true:  inventoryItem.tracked && availableForSale を要求（在庫切れ + バックオーダー無効を除外）
#   false: inventoryItem.tracked のみ（元バッチ仕様: 在庫0行も出力）
# STRICT_AVAILABILITY=false

# Bulk Operation の完了待機タイムアウト（ミリ秒、既定 60 分）
# BULK_TIMEOUT_MS=3600000
